# .gitignore — Dávidova cesta (offline static web app)

# Secrets — NEVER commit (there should be none in this project).
.env
.env.local
.env.*.local
*.key
*.pem
*credentials*
*token*

# Data + logs (in case any get generated by dev tooling)
data/
logs/
*.log

# Machine-local Claude Code permissions — where captured "allow" rules accumulate.
# Committed settings.json is shared; settings.local.json is personal + gitignored.
.claude/settings.local.json

# OS / editor junk
Thumbs.db
Desktop.ini
desktop.ini
.DS_Store
*.tmp
~$*

# Ikona priecinka (lokalne zobrazenie vo Windows Prieskumnikovi, S17) — korunka
# z INTRO. Nie je sucastou appky, len krasa priecinka na tomto stroji.
Davidova-cesta.ico

# BRS spec docs — kept LOCAL ONLY (contain camp location/dates/kids' ages).
# The repo is public, so these must never be pushed. They stay on disk as the spec.
BRS_fixed.docx
DavidovaCesta_Enterprise_BRS_v1.0.docx
*.docx

# Leader's printable manual — contains ALL 5 passwords (spoiler for kids).
# The repo is public, so this must NEVER be pushed. It lives on disk + in the
# hand-off ZIP for Janka only.
navod.html

# NOTE: app_images/ IS tracked — it's the app's artwork and not sensitive.
